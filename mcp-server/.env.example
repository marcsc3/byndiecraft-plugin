# AWS Bedrock Configuration
AWS_PROFILE=development
AWS_REGION=eu-central-1
CLAUDE_SONNET_4_5_MODEL_ID=arn:aws:bedrock:eu-central-1:<account-id>:application-inference-profile/<profile-id>

# GitHub Configuration
# Run "gh auth login" once - no token needed!
GITHUB_DEFAULT_OWNER=bynder
GITHUB_DEFAULT_REPO=byndiecraft-plugin

# Jira Configuration
JIRA_URL=https://bynder.atlassian.net

# Server Configuration
PORT=3000
